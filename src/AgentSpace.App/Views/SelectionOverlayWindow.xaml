<Window x:Class="AgentSpace.App.Views.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SelectionOverlayWindow" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="#40000000"
        Topmost="True" 
        ShowInTaskbar="False"
        Cursor="Cross"
        WindowState="Maximized"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Canvas Name="OverlayCanvas" Background="Transparent" 
            MouseDown="OverlayCanvas_MouseDown" 
            MouseMove="OverlayCanvas_MouseMove" 
            MouseUp="OverlayCanvas_MouseUp">
            
        <Grid Name="SelectionGrid" Visibility="Hidden" Canvas.Left="0" Canvas.Top="0">
            <!-- Background & Border -->
            <Border BorderBrush="DodgerBlue" BorderThickness="2" Background="#200080FF" Cursor="SizeAll" MouseDown="SelectionGrid_MouseDown"/>
            
            <!-- Custom Thumbs for 8 edges -->
            <Thumb Name="ThumbN" VerticalAlignment="Top" HorizontalAlignment="Stretch" Height="6" Margin="6,0,6,0" Cursor="SizeNS" DragDelta="Thumb_DragDelta">
                <Thumb.Template><ControlTemplate TargetType="Thumb"><Rectangle Fill="Transparent"/></ControlTemplate></Thumb.Template>
            </Thumb>
            <Thumb Name="ThumbS" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Height="6" Margin="6,0,6,0" Cursor="SizeNS" DragDelta="Thumb_DragDelta">
                <Thumb.Template><ControlTemplate TargetType="Thumb"><Rectangle Fill="Transparent"/></ControlTemplate></Thumb.Template>
            </Thumb>
            <Thumb Name="ThumbW" VerticalAlignment="Stretch" HorizontalAlignment="Left" Width="6" Margin="0,6,0,6" Cursor="SizeWE" DragDelta="Thumb_DragDelta">
                <Thumb.Template><ControlTemplate TargetType="Thumb"><Rectangle Fill="Transparent"/></ControlTemplate></Thumb.Template>
            </Thumb>
            <Thumb Name="ThumbE" VerticalAlignment="Stretch" HorizontalAlignment="Right" Width="6" Margin="0,6,0,6" Cursor="SizeWE" DragDelta="Thumb_DragDelta">
                <Thumb.Template><ControlTemplate TargetType="Thumb"><Rectangle Fill="Transparent"/></ControlTemplate></Thumb.Template>
            </Thumb>
            <Thumb Name="ThumbNW" VerticalAlignment="Top" HorizontalAlignment="Left" Width="6" Height="6" Cursor="SizeNWSE" DragDelta="Thumb_DragDelta">
                <Thumb.Template><ControlTemplate TargetType="Thumb"><Rectangle Fill="Transparent"/></ControlTemplate></Thumb.Template>
            </Thumb>
            <Thumb Name="ThumbNE" VerticalAlignment="Top" HorizontalAlignment="Right" Width="6" Height="6" Cursor="SizeNESW" DragDelta="Thumb_DragDelta">
                <Thumb.Template><ControlTemplate TargetType="Thumb"><Rectangle Fill="Transparent"/></ControlTemplate></Thumb.Template>
            </Thumb>
            <Thumb Name="ThumbSW" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="6" Height="6" Cursor="SizeNESW" DragDelta="Thumb_DragDelta">
                <Thumb.Template><ControlTemplate TargetType="Thumb"><Rectangle Fill="Transparent"/></ControlTemplate></Thumb.Template>
            </Thumb>
            <Thumb Name="ThumbSE" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="6" Height="6" Cursor="SizeNWSE" DragDelta="Thumb_DragDelta">
                <Thumb.Template><ControlTemplate TargetType="Thumb"><Rectangle Fill="Transparent"/></ControlTemplate></Thumb.Template>
            </Thumb>

            <!-- Control Panel (Pin/Cancel) -->
            <StackPanel Name="ControlPanel" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,-35">
                <Button Content="✓ Pin" Width="50" Height="25" Margin="0,0,5,0" Click="PinButton_Click" Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                <Button Content="✕ Cancel" Width="60" Height="25" Click="CancelButton_Click" Background="#F44336" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Canvas>
</Window>
